{
  "plugin": {
    "label": "Anthropic",
    "description": "Anthropic Messages API 模型供应商运行时扩展。"
  },
  "provider": {
    "label": "Anthropic"
  },
  "fields": {
    "base_url": {
      "label": "基础地址"
    },
    "api_key": {
      "label": "API Key"
    },
    "proxy_url": {
      "label": "代理地址",
      "description": "可选 HTTP 代理地址，用于模型供应商请求。"
    },
    "validate_model": {
      "label": "按发现目录校验模型"
    },
    "anthropic_version": {
      "label": "Anthropic Version"
    }
  },
  "models": {
    "claude-opus-4-1-20250805": {
      "label": "Claude Opus 4.1"
    },
    "claude-sonnet-4-20250514": {
      "label": "Claude Sonnet 4"
    },
    "claude-3-5-haiku-20241022": {
      "label": "Claude Haiku 3.5"
    }
  },
  "parameters": {
    "title": "Anthropic Messages 参数",
    "description": "Anthropic Messages API 调用桥支持的供应商级请求参数。",
    "thinking_type": {
      "label": "扩展思考",
      "description": "为兼容的 Claude 模型启用 extended thinking。",
      "options": {
        "enabled": {
          "label": "启用"
        },
        "disabled": {
          "label": "关闭"
        }
      }
    },
    "thinking_budget_tokens": {
      "label": "思考预算 Token 数",
      "description": "extended thinking 使用的 token 预算，必须小于最大 Token 数。"
    },
    "temperature": {
      "label": "温度",
      "description": "控制输出随机性。"
    },
    "top_p": {
      "label": "Top P",
      "description": "nucleus sampling 采样阈值。"
    },
    "top_k": {
      "label": "Top K",
      "description": "按排序限制候选 token。"
    },
    "max_output_tokens": {
      "label": "最大 Token 数",
      "description": "最大输出 token 数。"
    },
    "tool_choice": {
      "label": "工具选择",
      "description": "控制模型是否可以或必须调用工具。",
      "options": {
        "auto": {
          "label": "自动"
        },
        "any": {
          "label": "任意工具"
        },
        "none": {
          "label": "不使用"
        }
      }
    }
  }
}
