    },
    "tool_choice": {
      "label": "工具选择",
      "description": "控制模型是否可以或必须调用工具。",
      "options": {
        "none": {
          "label": "不使用"
        },
        "auto": {
          "label": "自动"
        },
        "required": {
          "label": "必须"
        }
      }
