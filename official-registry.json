              "presence_penalty": {
                "label": "存在惩罚",
                "description": "提高模型谈论新主题的倾向，值越高越不容易重复已出现内容。"
              },
              "frequency_penalty": {
                "label": "频率惩罚",
                "description": "按 token 出现频率降低重复用词概率，值越高越抑制高频重复。"
              },
              "stop": {
                "label": "停止词",
                "description": "指定停止生成的文本片段；支持单个字符串或字符串数组 JSON。",
